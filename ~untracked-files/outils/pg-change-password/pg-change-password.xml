<?xml version="1.0" encoding="UTF-8"?>
<!-- ======================================================================
    11/2025

     pg-change-password
     Modifier le mot de passe du compte administrateur d'une base PostgreSQL

     E. Amblard
     ====================================================================== -->

<project name="pg-change-password" default="main">
  <description>
    Modifier le mot de passe du compte administrateur d'une base PostgreSQL
  </description>

  <!-- =================================
          target: main
         ================================= -->
  <target name="main" depends="saisie,prepare"
    description="Modifier le mot de passe du compte administrateur d'une base PostgreSQL">

    <!-- Modifie le mot de passe -->
    <antcall target="change-pwd" />

    <!-- Démarre le service -->
    <antcall target="start-pg" />

  </target>


  <!-- =================================
          target: saisie
         ================================= -->
  <target name="saisie">

    <property name="path.exe.elevate" location="elevate.exe" />
    <echo>${path.exe.elevate}</echo>
    <echo>${server.service}</echo>


    <!-- Choix de la version de PostgreSQL -->

    <input message="Version de PostgreSQL ?" defaultvalue="18" validargs="18,17,16,15,14,13,12"
      addproperty="pg.version" id="swing">
      <handler id="input.handler.swing"
        classname="com.oxygenxml.ant.inputhandler.SwingInputHandlerImpl"
        classpath="swing-input-handler.jar" />
    </input>

    <!-- Choix du n° de port -->

    <input message="N° de port ?" addproperty="pg.port" defaultvalue="5432">
      <handler classname="com.oxygenxml.ant.inputhandler.SwingInputHandlerImpl"
        classpath="swing-input-handler.jar" />
    </input>

    <!-- Choix du nouveau mot de passe -->

    <input message="Nouveau mot de passe ?" addproperty="pg.password" defaultvalue="postgres">
      <handler classname="com.oxygenxml.ant.inputhandler.SwingInputHandlerImpl"
        classpath="swing-input-handler.jar" />
    </input>


    <!-- Paramètres globaux du traitement -->

    <property name="pg.host" value="localhost" />
    <property name="pg.database" value="postgres" />
    <property name="pg.user" value="postgres" />

    <property name="pg.dir.home" location="C:/Program Files/PostgreSQL/${pg.version}" />
    <property name="pg.dir.bin" location="${pg.dir.home}/bin" />
    <property name="pg.dir.data" location="${pg.dir.home}/data" />

    <property name="pg.service" value="postgresql-x64-${pg.version}" />


  </target>


  <!-- =================================
          target: prepare
         ================================= -->
  <target name="prepare">

    <!-- Vérifie l'existence du dossier de PostgreSQL -->

    <condition property="flag.dir.not.foud">
      <not>
        <available file="${pg.dir.home}" />
      </not>
    </condition>
    <fail if="${flag.dir.not.foud}" message=".">
      ┌────────────────────────────────────────────────────────────┐
      │ Le dossier n'existe pas : ${pg.dir.home}
      └────────────────────────────────────────────────────────────┘
    </fail>

    <!-- Arrête le service -->
    <antcall target="stop-pg" />


    <!-- Vérifie que PostgreSQL est arrêté -->

    <exec executable="ping" failonerror="false">
      <arg line="-n 2" />
      <arg value="localhost" />
    </exec>
    <exec executable="${pg.dir.bin}/pg_isready" failonerror="false" resultproperty="pg.ready">
      <arg value="--host=${pg.host}" />
      <arg value="--port=${pg.port}" />
    </exec>
    <condition property="flag.pg.started">
      <equals arg1="0" arg2="${pg.ready}" />
    </condition>
    <fail if="${flag.pg.started}" message=".">
      ┌──────────────────────────────────────────┐
      │ Veuillez arrêter PostgreSQL au préalable │
      └──────────────────────────────────────────┘
    </fail>

  </target>


  <!-- =================================
          target: change-pwd
         ================================= -->
  <target name="change-pwd">

    <!-- Sauvegarde du fichier de configuraiton -->

    <copy file="${pg.dir.data}/pg_hba.conf" tofile="${pg.dir.data}/pg_hba.conf.bak" overwrite="true" />


    <!-- Supprime l'authentification par moot de passe  -->

    <replace file="${pg.dir.data}/pg_hba.conf" token="md5" value="trust" />
    <replace file="${pg.dir.data}/pg_hba.conf" token="scram-sha-256" value="trust" />


    <!-- Démarre PostgreSQL -->

    <exec executable="${pg.dir.bin}/pg_ctl" resultproperty="result.start">
      <arg value="start" />
      <arg value="-D" />
      <arg path="${pg.dir.data}" />
    </exec>


    <!-- Change le mot de passe du compte administrateur -->

    <exec executable="${pg.dir.bin}/psql" resultproperty="result.psql">
      <arg value="--host=${pg.host}" />
      <arg value="--port=${pg.port}" />
      <arg value="--dbname=${pg.database}" />
      <arg value="--username=${pg.user}" />
      <arg value="-c" />
      <arg value="ALTER USER ${pg.user} WITH PASSWORD '${pg.password}'" />
    </exec>


    <!-- Arrête PostgreSQL -->

    <exec executable="${pg.dir.bin}/pg_ctl" resultproperty="result.stop">
      <arg value="stop" />
      <arg value="--mode=immediate" />
      <arg value="--pgdata=${pg.dir.data}" />
    </exec>


    <!-- Restaure la sauvegarde du fichier de configuraiton -->
    <!-- pour rétablir l'authentification par mot de passe -->

    <move file="${pg.dir.data}/pg_hba.conf.bak" tofile="${pg.dir.data}/pg_hba.conf" overwrite="true" />


    <!-- Identifiaction d'un éventuel échec -->

    <condition property="error.start">
      <not>
        <equals arg1="0" arg2="${result.start}" />
      </not>
    </condition>
    <condition property="error.psql">
      <not>
        <equals arg1="0" arg2="${result.psql}" />
      </not>
    </condition>
    <condition property="error.stop">
      <not>
        <equals arg1="0" arg2="${result.stop}" />
      </not>
    </condition>

    <fail if="${error.start}" message=".">
      ┌──────────────────────┐
      │ Erreur pendant start │
      └──────────────────────┘
    </fail>
    <fail if="${error.psql}" message=".">
      ┌──────────────────────┐
      │ Erreur pendant psql │
      └──────────────────────┘
    </fail>
    <fail if="${error.stop}" message=".">
      ┌──────────────────────┐
      │ Erreur pendant stop │
      └──────────────────────┘
    </fail>

  </target>


  <!-- =================================
          target: start-pg
         ================================= -->
  <target name="start-pg">

    <exec executable="${path.exe.elevate}">
      <arg line="NET START ${pg.service}" />
    </exec>

  </target>


  <!-- =================================
          target: stop-pg
         ================================= -->
  <target name="stop-pg">

    <exec executable="${path.exe.elevate}">
      <arg line='CMD /C' />
      <arg line='"NET STOP ${pg.service}"' />
    </exec>

  </target>


</project>